<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup Label="Globals">
        <SccProjectName>SAK</SccProjectName>
        <SccProvider>SAK</SccProvider>
        <SccAuxPath>SAK</SccAuxPath>
        <SccLocalPath>SAK</SccLocalPath>
    </PropertyGroup>

    <PropertyGroup>
        <TargetFrameworks>net10.0;net9.0;net8.0;</TargetFrameworks>
        <IsPackable>false</IsPackable>
        <NoWarn>$(NoWarn);CS1705</NoWarn>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Breakdance.AspNetCore" Version="7.*" />
        <PackageReference Include="Breakdance.Extensions.MSTest2" Version="7.*" />
        <PackageReference Include="Microsoft.Extensions.Logging.ApplicationInsights" Version="2.*" />
        <PackageReference Include="Microsoft.Restier.AspNetCore" Version="1.*-*" />
        <PackageReference Include="Microsoft.Restier.Breakdance" Version="1.*-*" />
        <PackageReference Include="Microsoft.Restier.EntityFramework" Version="1.*" />
        <PackageReference Include="SimpleMessageBus.Publish" Version="5.*" />
        <PackageReference Include="Simple.OData.V4.Client" Version="6.*-*" NoWarn="NU1608" />
    </ItemGroup>

    <ItemGroup Condition="'$(TargetFramework)'=='net9.0'">
        <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="9.*" NoWarn="NU1608" />
        <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="9.*" />
        <PackageReference Include="System.Text.Json" Version="9.*" />
        <!-- Transient package fixes to deal with .NET 9.0 RCs -->
        <PackageReference Include="Microsoft.Extensions.Configuration.Binder" Version="9.*" />
    </ItemGroup>

    <ItemGroup Condition="'$(TargetFramework)'=='net8.0'">
        <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="8.*" NoWarn="NU1608" />
        <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="8.*" />
        <PackageReference Include="System.Text.Json" Version="8.*" />
    </ItemGroup>

    <ItemGroup>
        <Compile Include="..\CloudNimble.EasyAF.Tests.CodeGen\Baselines\ApiControllers\EasyAFEntitiesApi.Generated.cs" Link="Api\EasyAFEntitiesApi.Generated.cs" />
        <Compile Include="..\CloudNimble.EasyAF.Tests.CodeGen\Baselines\ModelBuilder\EasyAFEntitiesModelBuilder.Generated.cs" Link="Api\EasyAFEntitiesModelBuilder.Generated.cs" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\CloudNimble.EasyAF.Core\CloudNimble.EasyAF.Core.csproj" />
        <ProjectReference Include="..\CloudNimble.EasyAF.Configuration\CloudNimble.EasyAF.Configuration.csproj" />
        <ProjectReference Include="..\CloudNimble.EasyAF.Data.EF6\CloudNimble.EasyAF.Data.EF6.csproj" />
        <ProjectReference Include="..\CloudNimble.EasyAF.Http\CloudNimble.EasyAF.Http.csproj" />
        <ProjectReference Include="..\CloudNimble.EasyAF.Restier.Breakdance\CloudNimble.EasyAF.Restier.Breakdance.csproj" />
        <ProjectReference Include="..\CloudNimble.EasyAF.Restier.EF6\CloudNimble.EasyAF.Restier.EF6.csproj" />
        <ProjectReference Include="..\CloudNimble.EasyAF.Tests.Shared\CloudNimble.EasyAF.Tests.Shared.csproj" />
    </ItemGroup>

    <ItemGroup>
        <None Update="appsettings.json">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </None>
        <None Update="appsettings.*.json">
            <DependentUpon>appsettings.json</DependentUpon>
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </None>
    </ItemGroup>

    <ItemGroup>
      <Folder Include="Baselines\" />
    </ItemGroup>

</Project>
