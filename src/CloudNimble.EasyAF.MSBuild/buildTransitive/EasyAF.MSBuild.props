<Project>
  <!-- Automatically apply ExcludeAssets to all Microsoft.Build packages for MSBL001 compliance -->
  <!-- This file is included transitively by all projects that reference CloudNimble.EasyAF.MSBuild -->
  <ItemGroup>
    <PackageReference Update="Microsoft.Build" ExcludeAssets="runtime" />
    <PackageReference Update="Microsoft.Build.Framework" ExcludeAssets="runtime" />
    <PackageReference Update="Microsoft.Build.Locator" ExcludeAssets="runtime" />
    <PackageReference Update="Microsoft.Build.Tasks.Core" ExcludeAssets="runtime" />
    <PackageReference Update="Microsoft.Build.Utilities.Core" ExcludeAssets="runtime" />
  </ItemGroup>
</Project>
