<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!--
    This targets file is automatically imported by projects that reference EasyAF.MSBuild.
    It adds the necessary Microsoft.Build packages so that MSBuildLocator can redirect
    to the correct SDK version at runtime.
  -->

  <ItemGroup>
    <!-- ExcludeAssets="runtime" is critical - we compile against these packages but
         MSBuildLocator redirects to the SDK's assemblies at runtime -->
    <PackageReference Include="Microsoft.Build" Version="17.14.*" ExcludeAssets="runtime" />
    <PackageReference Include="Microsoft.Build.Framework" Version="17.14.*" ExcludeAssets="runtime" />
    <PackageReference Include="Microsoft.Build.Locator" Version="1.*" />
    <PackageReference Include="Microsoft.Build.Tasks.Core" Version="17.14.*" ExcludeAssets="runtime" />
    <PackageReference Include="Microsoft.Build.Utilities.Core" Version="17.14.*" ExcludeAssets="runtime" />
  </ItemGroup>

</Project>
