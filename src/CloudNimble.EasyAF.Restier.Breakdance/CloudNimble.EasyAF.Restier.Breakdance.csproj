        <!-- Transient package fixes to deal with .NET 10.0 RCs -->
        <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="[10.*-*, 11.0.0)" NoWarn="NU1608" />
        <!--
        <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="[10.*-*, 11.0.0)" />
        <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" Version="[10.*-*, 11.0.0)" />
        <PackageReference Include="Microsoft.Extensions.Http" Version="[10.*-*, 11.0.0)" />
        <PackageReference Include="System.Net.Http.Json" Version="[10.*-*, 11.0.0)" />
        <PackageReference Include="Microsoft.Extensions.Configuration.Binder" Version="[10.*-*, 11.0.0)" />-->
