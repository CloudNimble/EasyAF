<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <PackageId>EasyAF</PackageId>
        <PackAsTool>True</PackAsTool>
    </PropertyGroup>

    <PropertyGroup>
        <ToolCommandName>dotnet-easyaf</ToolCommandName>
        <OutputType>Exe</OutputType>
        <TargetFrameworks>net10.0;net9.0;net8.0;</TargetFrameworks>
        <DocumentationFile>$(DocumentationFile)\$(AssemblyName).xml</DocumentationFile>
        <NoWarn>$(NoWarn);CA1822;NU1701;NU1608;</NoWarn>
        <AutoGenerateBindingRedirects>false</AutoGenerateBindingRedirects>
        <DisableMSBuildAssemblyCopyCheck>true</DisableMSBuildAssemblyCopyCheck>
    </PropertyGroup>

    <ItemGroup>
      <None Remove="deps.json" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="McMaster.Extensions.Hosting.CommandLine" Version="5.*" />
    </ItemGroup>

    <ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
        <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.*" />
        <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.*" />
        <PackageReference Include="Microsoft.Extensions.Logging" Version="10.*" />
    </ItemGroup>

    <ItemGroup Condition="'$(TargetFramework)' == 'net9.0'">
        <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="9.*" />
        <PackageReference Include="Microsoft.Extensions.Hosting" Version="9.*" />
        <PackageReference Include="Microsoft.Extensions.Logging" Version="9.*" />
    </ItemGroup>

    <ItemGroup Condition="'$(TargetFramework)' == 'net8.0'">
        <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="9.*" />
        <PackageReference Include="Microsoft.Extensions.Hosting" Version="9.*" />
        <PackageReference Include="Microsoft.Extensions.Logging" Version="9.*" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\CloudNimble.EasyAF.CodeGen\CloudNimble.EasyAF.CodeGen.csproj" />
        <ProjectReference Include="..\CloudNimble.EasyAF.EFCoreToEdmx\CloudNimble.EasyAF.EFCoreToEdmx.csproj" />
        <ProjectReference Include="..\CloudNimble.EasyAF.MSBuild\CloudNimble.EasyAF.MSBuild.csproj" />
    </ItemGroup>

    <ItemGroup>
        <None Update="App.Config2">
            <CopyToOutputDirectory>Never</CopyToOutputDirectory>
        </None>
    </ItemGroup>

</Project>
